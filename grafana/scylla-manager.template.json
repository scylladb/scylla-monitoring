{
    "dashboard": {
        "class": "dashboard",
        "originalTitle": "Scylla Manager Metrics",
        "rows": [
            {
                "class": "row",
                "height": "150px",
                "panels": [
                    {
                        "class": "small_stat",
                        "span": 3,
                        "spec/title": "Manager",
                        "vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "noValue": " Offline",
                                "thresholds": {
                                    "mode": "absolute",
                                    "steps": [
                                        {
                                            "color": "red",
                                            "value": null
                                        },
                                        {
                                            "color": "green",
                                            "value": 0
                                        }
                                    ]
                                },
                                "mappings": [
                                    {
                                        "type": "value",
                                        "options": {
                                            "0": {
                                                "text": "Online"
                                            }
                                        }
                                    },
                                    {
                                        "type": "value",
                                        "options": {
                                            "1": {
                                                "text": "Offline"
                                            }
                                        }
                                    }
                                ]
                            }
                        },
                        "data/spec/queries/0/spec/query/spec/expr": "count(scrape_samples_scraped{job=\"scylla_manager\"}==0) OR vector(0)"
                    },
                    {
                        "class": "small_stat",
                        "spec/title": "Total Nodes",
                        "data/spec/queries/0/spec/query/spec/expr": "count(scylla_manager_healthcheck_cql_rtt_ms{cluster=\"$cluster\"})",
                        "data/spec/queries/0/spec/query/spec/legendFormat": "Total Nodes"
                    },
                    {
                        "class": "small_stat",
                        "spec/title": "CQL Fail",
                        "spec/description": "The number of nodes that Scylla manager CQL probe failed connecting to. It could indicate a network or a node problem",
                        "vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "custom": {},
                                "thresholds": {
                                    "mode": "absolute",
                                    "steps": [
                                        {
                                            "color": "green",
                                            "value": null
                                        },
                                        {
                                            "value": 0,
                                            "color": "green"
                                        },
                                        {
                                            "value": 1,
                                            "color": "red"
                                        }
                                    ]
                                }
                            }
                        },
                        "data/spec/queries/0/spec/query/spec/expr": "count((scylla_manager_healthcheck_cql_status{cluster=\"$cluster\"}==-1) and on(instance) (scylla_node_operation_mode{cluster=\"$cluster\"} == 3) ) OR vector(0)",
                        "data/spec/queries/0/spec/query/spec/legendFormat": "Nodes without CQL connection"
                    },
                    {
                        "gridPos": {
                            "w": 2,
                            "h": 6
                        },
                        "class": "vertical_lcd",
                        "span": 2,
                        "spec/title": "Repair",
                        "spec/vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "custom": {},
                                "unit": "percent",
                                "decimals": 0,
                                "thresholds": {
                                    "mode": "absolute",
                                    "steps": [
                                        {
                                            "color": "green",
                                            "value": null
                                        }
                                    ]
                                },
                                "mappings": []
                            },
                            "overrides": []
                        },
                        "spec/data/spec/queries/0/spec/query/spec/expr": "sum(scylla_manager_repair_progress{cluster=\"$cluster\", job=\"scylla_manager\"}) or on() manager:repair_progress{cluster=~\"[[cluster]]\"}*100"
                    },
                    {
                        "gridPos": {
                            "w": 2,
                            "h": 6
                        },
                        "class": "small_stat",
                        "spec/title": "Last repair",
                        "spec/description": "The time of the last successful repair",
                        "vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "custom": {},
                                "thresholds": {
                                    "mode": "absolute",
                                    "steps": []
                                },
                                "mappings": [],
                                "color": {
                                    "mode": "fixed",
                                    "fixedColor": "green"
                                },
                                "unit": "dateTimeAsIsoNoDateIfToday",
                                "noValue": "Never"
                            },
                            "overrides": []
                        },
                        "data/spec/queries/0/spec/query/spec/expr": "manager:repair_done_ts{cluster=\"$cluster\"}*1000"
                    },
                    {
                        "gridPos": {
                            "w": 2,
                            "h": 6
                        },
                        "class": "small_stat",
                        "spec/title": "Last Failure",
                        "spec/description": "The time of the last failed repair",
                        "vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "custom": {},
                                "thresholds": {
                                    "mode": "absolute",
                                    "steps": []
                                },
                                "mappings": [],
                                "color": {
                                    "mode": "fixed",
                                    "fixedColor": "green"
                                },
                                "unit": "dateTimeAsIsoNoDateIfToday",
                                "noValue": "Never"
                            },
                            "overrides": []
                        },
                        "data/spec/queries/0/spec/query/spec/expr": "manager:repair_fail_ts{cluster=\"$cluster\"}*1000"
                    },
                    {
                        "gridPos": {
                            "w": 2,
                            "h": 6
                        },
                        "class": "vertical_lcd",
                        "span": 2,
                        "spec/title": "Backup",
                        "spec/vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "custom": {},
                                "unit": "percent",
                                "decimals": 0,
                                "thresholds": {
                                    "mode": "absolute",
                                    "steps": [
                                        {
                                            "color": "green",
                                            "value": null
                                        }
                                    ]
                                },
                                "mappings": []
                            },
                            "overrides": []
                        },
                        "spec/data/spec/queries/0/spec/query/spec/expr": "manager:backup_progress{cluster=~\"[[cluster]]\"}*100"
                    },
                    {
                        "gridPos": {
                            "w": 2,
                            "h": 6
                        },
                        "class": "small_stat",
                        "spec/title": "Last Backup",
                        "spec/description": "The time of the last successful backup",
                        "vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "custom": {},
                                "thresholds": {
                                    "mode": "absolute",
                                    "steps": []
                                },
                                "mappings": [],
                                "color": {
                                    "mode": "fixed",
                                    "fixedColor": "green"
                                },
                                "unit": "dateTimeAsIsoNoDateIfToday",
                                "noValue": "Never"
                            },
                            "overrides": []
                        },
                        "data/spec/queries/0/spec/query/spec/expr": "manager:backup_done_ts{cluster=\"$cluster\"}*1000"
                    },
                    {
                        "gridPos": {
                            "w": 2,
                            "h": 6
                        },
                        "class": "small_stat",
                        "spec/title": "Last Failure",
                        "spec/description": "The time of the last failed backup",
                        "vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "custom": {},
                                "thresholds": {
                                    "mode": "absolute",
                                    "steps": []
                                },
                                "mappings": [],
                                "color": {
                                    "mode": "fixed",
                                    "fixedColor": "green"
                                },
                                "unit": "dateTimeAsIsoNoDateIfToday",
                                "noValue": "Never"
                            },
                            "overrides": []
                        },
                        "data/spec/queries/0/spec/query/spec/expr": "manager:backup_fail_ts{cluster=\"$cluster\"}*1000"
                    }
                ],
                "title": "Summary row"
            },
            {
                "class": "row",
                "panels": [
                    {
                        "class": "percent_panel",
                        "span": 2,
                        "spec/title": "Repair Progress",
                        "spec/data/spec/queries/0/spec/query/spec/expr": "sum(scylla_manager_repair_progress{cluster=\"$cluster\", job=\"scylla_manager\"}) or on() manager:repair_progress{cluster=~\"[[cluster]]\"}*100"
                    },
                    {
                        "class": "ops_panel",
                        "spec/title": "Repair Token-Range Rate",
                        "spec/vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "links": [],
                                "unit": "si:tr/s"
                            },
                            "overrides": []
                        },
                        "spec/data/spec/queries/0/spec/query/spec/expr": "sum(rate(scylla_manager_repair_token_ranges_success{cluster=~\"[[cluster]]\", instance=~\"$instance\", shard=~\"$shard\"}[$__rate_interval])) by ([[by]])"
                    },
                    {
                        "class": "ops_panel",
                        "spec/title": "Repair Token-Range Error Rate",
                        "spec/vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "links": [],
                                "unit": "si:tr/s"
                            },
                            "overrides": []
                        },
                        "spec/data/spec/queries/0/spec/query/spec/expr": "sum(rate(scylla_manager_repair_token_ranges_error{cluster=~\"[[cluster]]\", instance=~\"$instance\", shard=~\"$shard\"}[$__rate_interval])) by ([[by]])"
                    }
                ],
                "title": "Repair rate Row"
            },
            {
                "class": "row",
                "panels": [
                    {
                        "class": "percentunit_panel",
                        "span": 2,
                        "spec/title": "Backup Progress",
                        "spec/data/spec/queries/0/spec/query/spec/expr": "manager:backup_progress{cluster=~\"[[cluster]]\"}"
                    },
                    {
                        "class": "ops_panel",
                        "span": 3,
                        "spec/title": "Uploaded bytes",
                        "spec/vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "links": [],
                                "unit": "decbytes"
                            },
                            "overrides": []
                        },
                        "spec/data/spec/queries/0/spec/query/spec/expr": "sum(scylla_manager_backup_files_uploaded_bytes{cluster=~\"[[cluster]]\", instance=~\"$instance\", shard=~\"$shard\"}) by ([[by]])"
                    },
                    {
                        "class": "ops_panel",
                        "span": 3,
                        "spec/title": "Uploaded skipped",
                        "spec/vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "links": [],
                                "unit": "decbytes"
                            },
                            "overrides": []
                        },
                        "spec/data/spec/queries/0/spec/query/spec/expr": "sum(scylla_manager_backup_files_skipped_bytes{cluster=~\"[[cluster]]\", instance=~\"$instance\", shard=~\"$shard\"}) by ([[by]])"
                    },
                    {
                        "class": "ops_panel",
                        "span": 3,
                        "spec/title": "Uploaded Failed",
                        "spec/vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "links": [],
                                "unit": "decbytes"
                            },
                            "overrides": []
                        },
                        "spec/data/spec/queries/0/spec/query/spec/expr": "sum(scylla_manager_backup_files_failed_bytes{cluster=~\"[[cluster]]\", instance=~\"$instance\", shard=~\"$shard\"}) by ([[by]])"
                    }
                ],
                "title": "Backup rate Row"
            },
            {
                "class": "row",
                "panels": [
                    {
                        "class": "percent_panel",
                        "span": 3,
                        "spec/title": "Restore Progress",
                        "spec/description": "Shows current restore progress",
                        "spec/data/spec/queries/0/spec/query/spec/expr": "scylla_manager_restore_progress{cluster=~\"[[cluster]]\"} < 100"
                    },
                    {
                        "class": "ops_panel",
                        "span": 3,
                        "spec/title": "Restore Remaining Bytes",
                        "spec/description": "Shows restore progress, the remaining bytes to complete",
                        "spec/vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "links": [],
                                "unit": "decbytes"
                            },
                            "overrides": []
                        },
                        "spec/data/spec/queries/0/spec/query/spec/expr": "sum(scylla_manager_restore_remaining_bytes{cluster=~\"[[cluster]]\", instance=~\"$instance\", shard=~\"$shard\"}) by ([[by]])"
                    },
                    {
                        "class": "percent_panel",
                        "span": 3,
                        "spec/title": "one to one Restore Progress",
                        "spec/description": "Shows current one to one restore progress",
                        "spec/data/spec/queries/0/spec/query/spec/expr": "scylla_manager_one2onerestore_progress{cluster=~\"[[cluster]]\"} < 100"
                    },
                    {
                        "class": "bytes_panel",
                        "span": 3,
                        "spec/title": "one to one Remaining Bytes",
                        "spec/description": "Shows one to one restore progress, the remaining bytes to complete",
                        "spec/vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "links": [],
                                "unit": "decbytes"
                            },
                            "overrides": []
                        },
                        "spec/data/spec/queries/0/spec/query/spec/expr": "sum(scylla_manager_one2onerestore_download_remaining_bytes{cluster=~\"[[cluster]]\", node=~\"$instance\"}) by ([[by]])"
                    }
                ],
                "title": "Backup Restore Bytes"
            },
            {
                "class": "row",
                "panels": [
                    {
                        "class": "ms_panel",
                        "spec/title": "CQL probe duration by $by",
                        "spec/description": "Average duration time for a CQL ping operation",
                        "spec/data/spec/queries/0/spec/query/spec/expr": "avg(scylla_manager_healthcheck_cql_rtt_ms{instance=~\"$instance\", cluster=~\"[[cluster]]\"}) by ($by)"
                    }
                ],
                "title": "SSH connection Row"
            },
            {
                "class": "row",
                "height": "25px",
                "gridPos": {
                    "h": 2
                },
                "panels": [
                    {
                        "class": "plain_text",
                        "spec/vizConfig/spec/options/content": "<h1 style=\"color:#5780C1; border-bottom: 3px solid #5780C1;\">Manager Agent</h1>"
                    }
                ],
                "hideHeader": true
            },
            {
                "class": "row",
                "panels": [
                    {
                        "class": "bytes_panel",
                        "spec/title": "Agent Memory Heap usage",
                        "spec/description": "An increase in memory can indicate an issue with the Manager agent",
                        "spec/data/spec/queries/0/spec/query/spec/expr": "sum(go_memstats_heap_inuse_bytes{job=~\"manager_agent.?\", instance=~\"$instance\"}) by ($by)"
                    },
                    {
                        "class": "graph_panel",
                        "spec/title": "Agent Threads",
                        "spec/description": "An increase in the number of threads can indicate an issue with the Manager agent",
                        "spec/data/spec/queries/0/spec/query/spec/expr": "avg(go_threads{job=~\"manager_agent.?\", instance=~\"$instance\"}) by ($by)"
                    }
                ],
                "title": "SSH connection Row"
            },
            {
                "class": "monitoring_version_row"
            }
        ],
        "tags": [
            "__SCYLLA_VERSION_DOT__"
        ],
        "time": {
            "from": "now-30m",
            "to": "now"
        },
        "overwrite": true,
        "version": 3,
        "spec/title": "Scylla Manager Metrics",
        "metadata/name": "manager-__SCYLLA_VERSION_DASHED__",
        "spec/variables": [
            {
                "kind": "CustomVariable",
                "spec": {
                    "name": "by",
                    "label": "by",
                    "multi": false,
                    "includeAll": false,
                    "options": [
                        {
                            "selected": true,
                            "text": "Cluster",
                            "value": "cluster"
                        },
                        {
                            "selected": false,
                            "text": "Instance",
                            "value": "instance"
                        },
                        {
                            "selected": false,
                            "text": "Keyspace",
                            "value": "keyspace"
                        },
                        {
                            "selected": false,
                            "text": "Shard",
                            "value": "shard"
                        }
                    ],
                    "current": {
                        "tags": [],
                        "text": "Cluster",
                        "value": "cluster"
                    },
                    "hide": "dontHide",
                    "query": "Instance,Shard,Keyspace,Cluster"
                }
            },
            {
                "kind": "QueryVariable",
                "spec": {
                    "current": {
                        "text": "",
                        "value": ""
                    },
                    "hide": "dontHide",
                    "refresh": "onTimeRangeChanged",
                    "skipUrlSync": false,
                    "query": {
                        "kind": "DataQuery",
                        "group": "prometheus",
                        "version": "v0",
                        "datasource": {
                            "name": "prometheus"
                        },
                        "spec": {
                            "__legacyStringValue": "label_values(scylla_manager_cluster_name,name)"
                        }
                    },
                    "regex": "",
                    "regexApplyTo": "value",
                    "sort": "alphabeticalAsc",
                    "definition": "",
                    "options": [],
                    "multi": false,
                    "includeAll": false,
                    "allowCustomValue": true,
                    "name": "cluster_name",
                    "label": "cluster"
                }
            },
            {
                "kind": "QueryVariable",
                "spec": {
                    "current": {
                        "text": "",
                        "value": ""
                    },
                    "hide": "hideVariable",
                    "refresh": "onTimeRangeChanged",
                    "skipUrlSync": false,
                    "query": {
                        "kind": "DataQuery",
                        "group": "prometheus",
                        "version": "v0",
                        "datasource": {
                            "name": "prometheus"
                        },
                        "spec": {
                            "__legacyStringValue": "label_values(scylla_manager_cluster_name{name=\"$cluster_name\"}, cluster)"
                        }
                    },
                    "regex": "",
                    "regexApplyTo": "value",
                    "sort": "alphabeticalAsc",
                    "definition": "",
                    "options": [],
                    "multi": false,
                    "includeAll": false,
                    "allowCustomValue": true,
                    "name": "cluster",
                    "label": "cluster_id"
                }
            },
            {
                "kind": "QueryVariable",
                "spec": {
                    "current": {
                        "text": "All",
                        "value": "$__all"
                    },
                    "hide": "dontHide",
                    "refresh": "onTimeRangeChanged",
                    "skipUrlSync": false,
                    "query": {
                        "kind": "DataQuery",
                        "group": "prometheus",
                        "version": "v0",
                        "datasource": {
                            "name": "prometheus"
                        },
                        "spec": {
                            "__legacyStringValue": "label_values(scylla_manager_healthcheck_cql_rtt_ms{cluster=\"$cluster\"}, instance)"
                        }
                    },
                    "regex": "",
                    "regexApplyTo": "value",
                    "sort": "alphabeticalAsc",
                    "definition": "",
                    "options": [],
                    "multi": true,
                    "includeAll": true,
                    "allValue": ".*",
                    "allowCustomValue": true,
                    "name": "instance",
                    "label": "instance"
                }
            },
            {
                "kind": "QueryVariable",
                "spec": {
                    "current": {
                        "text": "All",
                        "value": "$__all"
                    },
                    "hide": "dontHide",
                    "refresh": "onTimeRangeChanged",
                    "skipUrlSync": false,
                    "query": {
                        "kind": "DataQuery",
                        "group": "prometheus",
                        "version": "v0",
                        "datasource": {
                            "name": "prometheus"
                        },
                        "spec": {
                            "__legacyStringValue": "label_values(scylla_manager_repair_segments_total, shard)"
                        }
                    },
                    "regex": "",
                    "regexApplyTo": "value",
                    "sort": "numericalAsc",
                    "definition": "",
                    "options": [],
                    "multi": true,
                    "includeAll": true,
                    "allValue": ".*",
                    "allowCustomValue": true,
                    "name": "shard",
                    "label": "shard"
                }
            },
            {
                "kind": "CustomVariable",
                "spec": {
                    "current": {
                        "text": "__SCYLLA_VERSION_DOT__",
                        "value": "__SCYLLA_VERSION_DOT__"
                    },
                    "options": [
                        {
                            "selected": true,
                            "text": "__SCYLLA_VERSION_DOT__",
                            "value": "__SCYLLA_VERSION_DOT__"
                        }
                    ],
                    "multi": false,
                    "includeAll": false,
                    "hide": "hideVariable",
                    "skipUrlSync": false,
                    "allowCustomValue": true,
                    "valuesFormat": "csv",
                    "name": "scylla_version",
                    "query": "__SCYLLA_VERSION_DOT__"
                }
            },
            {
                "kind": "CustomVariable",
                "spec": {
                    "name": "monitoring_version",
                    "query": "__MONITOR_VERSION__",
                    "current": {
                        "text": "__MONITOR_VERSION__",
                        "value": "__MONITOR_VERSION__"
                    },
                    "options": [],
                    "multi": false,
                    "includeAll": false,
                    "hide": "hideVariable",
                    "skipUrlSync": false,
                    "allowCustomValue": true,
                    "valuesFormat": "csv"
                }
            }
        ],
        "spec/annotations": [
            {
                "class": "annotation_restart"
            },
            {
                "class": "annotation_manager_task"
            },
            {
                "class": "g13_annotation_manager_task_failed"
            }
        ]
    }
}