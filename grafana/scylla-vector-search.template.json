{
    "dashboard": {
        "class": "dashboard",
        "rows": [
            {
                "class": "row",
                "height": "150px",
                "panels": [
                    {
                        "gridPos": {
                            "w": 4,
                            "h": 5
                        },
                        "class": "small_stat",
                        "spec/title": "Status",
                        "vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "noValue": " Offline",
                                "thresholds": {
                                    "mode": "absolute",
                                    "steps": [
                                        {
                                            "color": "red",
                                            "value": null
                                        },
                                        {
                                            "color": "green",
                                            "value": 1
                                        }
                                    ]
                                },
                                "mappings": [
                                    {
                                        "type": "value",
                                        "options": {
                                            "0": {
                                                "text": "Offline"
                                            }
                                        }
                                    },
                                    {
                                        "type": "range",
                                        "options": {
                                            "from": 1,
                                            "to": null,
                                            "result": {
                                                "text": "Online",
                                                "index": 1,
                                                "color": "green"
                                            }
                                        }
                                    }
                                ]
                            }
                        },
                        "data/spec/queries/0/spec/query/spec/expr": "count(scrape_samples_scraped{job=\"vector_search\"}) OR vector(0)"
                    },
                    {
                        "gridPos": {
                            "w": 3,
                            "h": 5
                        },
                        "class": "small_stat",
                        "spec/title": "# Indexes",
                        "vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "mappings": [],
                                "thresholds": {
                                    "mode": "absolute",
                                    "steps": [
                                        {
                                            "color": "green",
                                            "value": null
                                        }
                                    ]
                                },
                                "unit": "",
                                "color": {
                                    "mode": "fixed",
                                    "fixedColor": "blue"
                                }
                            },
                            "overrides": []
                        },
                        "data/spec/queries/0/spec/query/spec/expr": "max(count(index_size{job=\"vector_search\", instance=~\"$node\"}) by (instance))"
                    },
                    {
                        "gridPos": {
                            "w": 3,
                            "h": 5
                        },
                        "class": "small_stat",
                        "spec/title": "Disk Usage",
                        "vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "custom": {
                                    "hideFrom": {
                                        "tooltip": false,
                                        "viz": false,
                                        "legend": false
                                    }
                                },
                                "color": {
                                    "mode": "palette-classic"
                                },
                                "mappings": [],
                                "unit": "decbytes"
                            },
                            "overrides": []
                        },
                        "data/spec/queries": [
                            {
                                "class": "graph_query",
                                "spec/query/spec/expr": "avg(sum(node_filesystem_size_bytes{job=\"vector_search_os\", instance=~\"$node\"} - node_filesystem_avail_bytes{job=\"vector_search_os\", instance=~\"$node\"}) by (instance, cluster))",
                                "spec/query/spec/legendFormat": "Used",
                                "spec/query/spec/instant": true,
                                "spec/query/spec/range": false
                            },
                            {
                                "class": "graph_query",
                                "spec/refId": "B",
                                "spec/query/spec/expr": "avg(sum(node_filesystem_avail_bytes{job=\"vector_search_os\", instance=~\"$node\"}) by (instance))",
                                "spec/query/spec/legendFormat": "Free"
                            }
                        ]
                    },
                    {
                        "gridPos": {
                            "w": 3,
                            "h": 5
                        },
                        "class": "small_stat",
                        "spec/title": "Disk Usage",
                        "vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "mappings": [],
                                "thresholds": {
                                    "mode": "absolute",
                                    "steps": [
                                        {
                                            "color": "green",
                                            "value": null
                                        }
                                    ]
                                },
                                "unit": "decbytes",
                                "color": {
                                    "mode": "fixed",
                                    "fixedColor": "blue"
                                }
                            },
                            "overrides": []
                        },
                        "data/spec/queries/0/spec/query/spec/expr": "avg(sum(node_filesystem_size_bytes{job=\"vector_search_os\", instance=~\"$node\"}) by (instance, cluster) -sum(node_filesystem_avail_bytes{job=\"vector_search_os\", instance=~\"$node\"}) by (instance, cluster)) by ([[by]])",
                        "data/spec/queries/0/spec/query/spec/legendFormat": "{{instance}}"
                    },
                    {
                        "gridPos": {
                            "w": 3,
                            "h": 5
                        },
                        "class": "small_stat_area",
                        "spec/title": "CPU",
                        "spec/description": "",
                        "vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "custom": {},
                                "unit": "percent",
                                "decimals": 0,
                                "thresholds": {
                                    "mode": "absolute",
                                    "steps": [
                                        {
                                            "color": "green",
                                            "value": null
                                        },
                                        {
                                            "color": "red",
                                            "value": 90
                                        }
                                    ]
                                },
                                "mappings": []
                            },
                            "overrides": []
                        },
                        "data/spec/queries/0/spec/query/spec/expr": "100*avg(sum(rate(node_cpu_seconds_total{job=\"vector_search_os\", mode!~\"idle\", instance=~\"$node\"}[1m])) by(cpu)) by ([[by]])"
                    },
                    {
                        "gridPos": {
                            "w": 3,
                            "h": 5
                        },
                        "class": "small_stat_area",
                        "spec/title": "Memory % Usage",
                        "vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "mappings": [],
                                "thresholds": {
                                    "mode": "absolute",
                                    "steps": [
                                        {
                                            "color": "green",
                                            "value": null
                                        },
                                        {
                                            "color": "red",
                                            "value": 0.8
                                        }
                                    ]
                                },
                                "unit": "percentunit",
                                "min": 0,
                                "max": 1,
                                "decimals": 0
                            },
                            "overrides": []
                        },
                        "data/spec/queries/0/spec/query/spec/expr": "1-avg(node_memory_MemAvailable_bytes{job=\"vector_search_os\", instance=~\"$node\"})/avg(node_memory_MemTotal_bytes{job=\"vector_search_os\", instance=~\"$node\"})",
                        "data/spec/queries/0/spec/query/spec/legendFormat": "Used"
                    },
                    {
                        "gridPos": {
                            "w": 3,
                            "h": 5
                        },
                        "class": "small_stat",
                        "spec/title": "Memory Usage",
                        "vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "mappings": [],
                                "thresholds": {
                                    "mode": "absolute",
                                    "steps": [
                                        {
                                            "color": "green",
                                            "value": null
                                        }
                                    ]
                                },
                                "unit": "decbytes",
                                "color": {
                                    "mode": "fixed",
                                    "fixedColor": "blue"
                                },
                                "min": 0
                            },
                            "overrides": []
                        },
                        "data/spec/queries/0/spec/query/spec/expr": "avg(node_memory_MemTotal_bytes{job=\"vector_search_os\", instance=~\"$node\"} - node_memory_MemAvailable_bytes{job=\"vector_search_os\", instance=~\"$node\"}) by ([[by]])",
                        "data/spec/queries/0/spec/query/spec/legendFormat": "{{instance}}"
                    }
                ],
                "title": "Summary row"
            },
            {
                "class": "row",
                "panels": [
                    {
                        "gridPos": {
                            "h": 8,
                            "w": 6
                        },
                        "class": "bytes_panel",
                        "spec/title": "Disk Usage by [[by]]",
                        "spec/description": "Average Disk Usage",
                        "spec/data/spec/queries/0/spec/query/spec/expr": "avg(sum(node_filesystem_size_bytes{job=\"vector_search_os\", instance=~\"$node\"}) by (cluster, dc, instance, rack)-sum(node_filesystem_avail_bytes{job=\"vector_search_os\", instance=~\"$node\"})by (cluster, dc, instance, rack)) by ([[by]])"
                    },
                    {
                        "gridPos": {
                            "h": 8,
                            "w": 6
                        },
                        "class": "bytes_panel",
                        "spec/title": "Memory Usage by [[by]]",
                        "spec/description": "Average Disk Usage",
                        "spec/data/spec/queries/0/spec/query/spec/expr": "avg(node_memory_MemTotal_bytes{job=\"vector_search_os\", instance=~\"$node\"}-node_memory_MemAvailable_bytes{job=\"vector_search_os\", instance=~\"$node\"}) by ([[by]])"
                    },
                    {
                        "gridPos": {
                            "h": 8,
                            "w": 6
                        },
                        "class": "percentunit_panel",
                        "spec/title": "CPU Usage by [[by]]",
                        "spec/description": "Average CPU Usage",
                        "spec/data/spec/queries/0/spec/query/spec/expr": "avg(sum(rate(node_cpu_seconds_total{mode != \"idle\", instance=~\"$node\"}[1m])) by (cluster, cpu, instance)) by ([[by]])"
                    }
                ],
                "title": "OS Information"
            },
            {
                "class": "row",
                "panels": [
                    {
                        "span": 2,
                        "class": "graph_panel",
                        "spec/title": "Stored Vectors in index",
                        "spec/description": "Number of stored vectors in the index",
                        "spec/vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "class": "fieldConfig_defaults",
                                "unit": "si:Vectors"
                            },
                            "overrides": []
                        },
                        "spec/data/spec/queries/0/spec/query/spec/expr": "avg(index_size{index_name=\"$index\", instance=~\"$node\"}) by ([[by]], index_name)",
                        "spec/data/spec/queries/0/spec/query/spec/legendFormat": "{{instance}} {{index_name}}"
                    },
                    {
                        "span": 2,
                        "class": "ops_panel",
                        "spec/title": "Index build rate",
                        "spec/description": "Rate of new vectors being added to the index",
                        "spec/vizConfig/spec/fieldConfig": {
                            "defaults": {
                                "class": "fieldConfig_defaults",
                                "unit": "recps"
                            },
                            "overrides": []
                        },
                        "spec/data/spec/queries/0/spec/query/spec/expr": "avg(rate(index_size{index_name=\"$index\", instance=~\"$node\"}[$__rate_interval])) by ([[by]], index_name)",
                        "spec/data/spec/queries/0/spec/query/spec/legendFormat": "{{instance}} {{index_name}}"
                    },
                    {
                        "span": 2,
                        "class": "ops_panel",
                        "spec/title": "Index requests rate",
                        "spec/description": "Rate of requests to the index",
                        "spec/data/spec/queries/0/spec/query/spec/expr": "avg(rate(request_latency_seconds_count{index_name=\"$index\", instance=~\"$node\"}[$__rate_interval])) by ([[by]], index_name)",
                        "spec/data/spec/queries/0/spec/query/spec/legendFormat": "{{instance}} {{index_name}}"
                    },
                    {
                        "span": 2,
                        "class": "seconds_panel",
                        "spec/title": "Average Latency",
                        "spec/description": "Average latency of requests to the index",
                        "spec/data/spec/queries/0/spec/query/spec/expr": "avg(rate(request_latency_seconds_sum{index_name=\"$index\", instance=~\"$node\"}[$__rate_interval])/rate(request_latency_seconds_count{index_name=\"$index\", instance=~\"$node\"}[$__rate_interval])) by ([[by]], index_name)",
                        "spec/data/spec/queries/0/spec/query/spec/legendFormat": "{{instance}} {{index_name}}"
                    },
                    {
                        "span": 2,
                        "class": "seconds_panel",
                        "spec/title": "P95 Latency",
                        "spec/description": "95th percentile latency of requests to the index",
                        "spec/data/spec/queries/0/spec/query/spec/expr": "histogram_quantile(0.95, sum(rate(request_latency_seconds_bucket{index_name=\"$index\", instance=~\"$node\"}[$__rate_interval])) by ([[by]], keyspace,index_name, le))",
                        "spec/data/spec/queries/0/spec/query/spec/legendFormat": "{{instance}} {{index_name}}"
                    },
                    {
                        "span": 2,
                        "class": "seconds_panel",
                        "spec/title": "P99 Latency",
                        "spec/description": "99th percentile latency of requests to the index",
                        "spec/data/spec/queries/0/spec/query/spec/expr": "histogram_quantile(0.99, sum(rate(request_latency_seconds_bucket{index_name=\"$index\", instance=~\"$node\"}[$__rate_interval])) by ([[by]], keyspace,index_name, le))",
                        "spec/data/spec/queries/0/spec/query/spec/legendFormat": "{{instance}} {{index_name}}"
                    }
                ],
                "title": "Index Row",
                "collapse": false
            },
            {
                "title": "",
                "collapse": false,
                "rows": [
                    {
                        "class": "monitoring_version_row"
                    }
                ]
            }
        ],
        "tags": [
            "__SCYLLA_VERSION_DOT__"
        ],
        "time": {
            "from": "now-30m",
            "to": "now"
        },
        "overwrite": true,
        "version": 1,
        "spec/title": "Vector Search",
        "metadata/name": "vector-search-__SCYLLA_VERSION_DASHED__",
        "spec/variables": [
            {
                "kind": "CustomVariable",
                "spec": {
                    "name": "by",
                    "query": "Cluster : cluster, Node : instance",
                    "current": {
                        "tags": [],
                        "text": "Cluster",
                        "value": "cluster"
                    },
                    "options": [
                        {
                            "selected": true,
                            "text": "Cluster",
                            "value": "cluster"
                        },
                        {
                            "selected": false,
                            "text": "Node",
                            "value": "instance"
                        }
                    ],
                    "multi": false,
                    "includeAll": false,
                    "label": "by",
                    "hide": "dontHide",
                    "skipUrlSync": false,
                    "allowCustomValue": true,
                    "valuesFormat": "csv"
                }
            },
            {
                "kind": "QueryVariable",
                "spec": {
                    "current": {
                        "text": "All",
                        "value": "$__all"
                    },
                    "hide": "dontHide",
                    "refresh": "onTimeRangeChanged",
                    "skipUrlSync": false,
                    "query": {
                        "kind": "DataQuery",
                        "group": "prometheus",
                        "version": "v0",
                        "datasource": {
                            "name": "prometheus"
                        },
                        "spec": {
                            "__legacyStringValue": "label_values(node_memory_MemAvailable_bytes{job=\"vector_search_os\"}, instance)"
                        }
                    },
                    "regex": "",
                    "regexApplyTo": "value",
                    "sort": "alphabeticalAsc",
                    "definition": "",
                    "options": [],
                    "multi": true,
                    "includeAll": true,
                    "allValue": "..*",
                    "allowCustomValue": true,
                    "name": "node",
                    "label": "Node"
                }
            },
            {
                "kind": "QueryVariable",
                "spec": {
                    "current": {
                        "text": "All",
                        "value": "$__all"
                    },
                    "hide": "dontHide",
                    "refresh": "onTimeRangeChanged",
                    "skipUrlSync": false,
                    "query": {
                        "kind": "DataQuery",
                        "group": "prometheus",
                        "version": "v0",
                        "datasource": {
                            "name": "prometheus"
                        },
                        "spec": {
                            "__legacyStringValue": "label_values(index_size{},index_name)"
                        }
                    },
                    "regex": "",
                    "regexApplyTo": "value",
                    "sort": "numericalAsc",
                    "definition": "",
                    "options": [],
                    "multi": true,
                    "includeAll": true,
                    "allValue": ".*",
                    "allowCustomValue": true,
                    "name": "index",
                    "label": "index"
                }
            },
            {
                "kind": "CustomVariable",
                "spec": {
                    "current": {
                        "text": "__SCYLLA_VERSION_DOT__",
                        "value": "__SCYLLA_VERSION_DOT__"
                    },
                    "options": [
                        {
                            "selected": true,
                            "text": "__SCYLLA_VERSION_DOT__",
                            "value": "__SCYLLA_VERSION_DOT__"
                        }
                    ],
                    "multi": false,
                    "includeAll": false,
                    "hide": "hideVariable",
                    "skipUrlSync": false,
                    "allowCustomValue": true,
                    "valuesFormat": "csv",
                    "name": "scylla_version",
                    "query": "__SCYLLA_VERSION_DOT__"
                }
            },
            {
                "kind": "CustomVariable",
                "spec": {
                    "name": "monitoring_version",
                    "query": "__MONITOR_VERSION__",
                    "current": {
                        "text": "__MONITOR_VERSION__",
                        "value": "__MONITOR_VERSION__"
                    },
                    "options": [],
                    "multi": false,
                    "includeAll": false,
                    "hide": "hideVariable",
                    "skipUrlSync": false,
                    "allowCustomValue": true,
                    "valuesFormat": "csv"
                }
            }
        ]
    }
}