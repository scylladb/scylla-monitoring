                                "span": 4
                            },
                            {
                                "class": "ops_panel",
                                "span": 2,
                                "spec/title": "Writes/s",
                                "spec/description": "Write attempts - include all writes that reached the coordinator node, even if they will eventually fail",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "round(sum(rate(scylla_storage_proxy_coordinator_write_latency_summary_count{cluster=\"$cluster\", dc=~\"$dc\", scheduling_group_name=~\"$sg\"}[$__rate_interval])) by (scheduling_group_name))",
                                "spec/data/spec/queries/0/spec/query/spec/legendFormat": "{{scheduling_group_name}} Writes/s"
                            },
                            {
                                "class": "us_panel",
                                "span": 2,
                                "spec/title": "Average Write Latencies",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "wlatencya{by=\"cluster\", cluster=\"$cluster\",scheduling_group_name=~\"$sg\"}>0",
                                "spec/data/spec/queries/0/spec/query/spec/legendFormat": "{{scheduling_group_name}}",
                                "spec/vizConfig/spec/options/legend": {
                                    "displayMode": "list",
                                    "placement": "bottom",
                                    "showLegend": true
                                }
                            },
                            {
                                "class": "us_panel",
                                "span": 2,
                                "spec/title": "Write Latencies",
                                "spec/data/spec/queries": [
                                    {
                                        "class": "graph_query",
                                        "spec/query/spec/expr": "wlatencyp95{by=\"cluster\", cluster=\"$cluster\",scheduling_group_name=~\"$sg\"}>0",
                                        "spec/query/spec/legendFormat": "{{scheduling_group_name}} 95%"
                                    },
                                    {
                                        "class": "graph_query",
                                        "spec/refId": "B",
                                        "spec/query/spec/expr": "wlatencyp99{by=\"cluster\", cluster=\"$cluster\",scheduling_group_name=~\"$sg\"}>0",
                                        "spec/query/spec/legendFormat": "{{scheduling_group_name}} 99%"
