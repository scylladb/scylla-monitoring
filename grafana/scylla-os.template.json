{
    "dashboard": {
        "class": "dashboard",
        "overwrite": true,
        "rows": [
            {
                "title": "Cluster OS Information $cluster $account_name $cluster_name ",
                "collapse": false,
                "rows": [
                    {
                        "class": "row",
                        "panels": [
                            {
                                "class": "piechart_panel_percent",
                                "gridPos": {
                                    "h": 6,
                                    "w": 5
                                },
                                "spec/data/spec/queries": [
                                    {
                                        "class": "panel_query",
                                        "spec/query/spec/expr": "sum(node_filesystem_avail_bytes{mountpoint=~\"$mount_point\", instance=~\"$node\", job=~\"node_exporter.*\"})",
                                        "spec/query/spec/legendFormat": "Free",
                                        "spec/query/spec/instant": true,
                                        "spec/query/spec/range": false
                                    },
                                    {
                                        "class": "panel_query",
                                        "spec/refId": "B",
                                        "spec/query/spec/expr": "(sum(node_filesystem_size_bytes{mountpoint=~\"$mount_point\", instance=~\"$node\", job=~\"node_exporter.*\"})-sum(node_filesystem_avail_bytes{mountpoint=~\"$mount_point\", instance=~\"$node\", job=~\"node_exporter.*\"}))",
                                        "spec/query/spec/legendFormat": "Used",
                                        "spec/query/spec/instant": true,
                                        "spec/query/spec/range": false
                                    }
                                ],
                                "spec/title": "Total Storage $node"
                            },
                            {
                                "class": "device_table"
                            },
                            {
                                "class": "low_disk_partitions_table"
                            }
                        ]
                    }
                ]
            },
            {
                "title": "Partition $mount_point",
                "collapse": false,
                "repeat": "mount_point",
                "rows": [
                    {
                        "class": "row",
                        "panels": [
                            {
                                "span": 3,
                                "class": "percentunit_panel",
                                "spec/title": "Used disk by $by",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "1-sum(node_filesystem_avail_bytes{mountpoint=\"$mount_point\", instance=~\"$node\", job=~\"node_exporter.*\"}) by ([[by]])/sum(node_filesystem_size_bytes{mountpoint=\"$mount_point\", instance=~\"$node\", job=~\"node_exporter.*\"}) by ([[by]])"
                            },
                            {
                                "span": 3,
                                "class": "bytes_panel",
                                "spec/title": "Used Bytes by $by",
                                "spec/data/spec/queries": [
                                    {
                                        "class": "graph_query",
                                        "spec/query/spec/expr": "sum(node_filesystem_size_bytes{mountpoint=\"$mount_point\", instance=~\"$node\", job=~\"node_exporter.*\"}) by ([[by]])-sum(node_filesystem_avail_bytes{mountpoint=\"$mount_point\", instance=~\"$node\", job=~\"node_exporter.*\"}) by ([[by]])"
                                    },
                                    {
                                        "class": "graph_query",
                                        "spec/refId": "B",
                                        "spec/query/spec/expr": "sum(node_filesystem_size{mountpoint=\"$mount_point\", instance=~\"$node\", job=~\"node_exporter.*\"}) by ([[by]])-sum(node_filesystem_avail{mountpoint=\"$mount_point\", instance=~\"$node\", job=~\"node_exporter.*\"}) by ([[by]])"
                                    }
                                ]
                            },
                            {
                                "span": 3,
                                "class": "bytes_panel",
                                "spec/title": "Free Bytes by $by",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(node_filesystem_free_bytes{mountpoint=\"$mount_point\", instance=~\"$node\", job=~\"node_exporter.*\"}) by ([[by]])"
                            },
                            {
                                "span": 3,
                                "class": "graph_panel",
                                "spec/title": "Number of files by $by",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(node_filesystem_files{mountpoint=\"$mount_point\", instance=~\"$node\", job=~\"node_exporter.*\"}- node_filesystem_files_free{mountpoint=\"$mount_point\", instance=~\"$node\", job=~\"node_exporter.*\"}) by ([[by]])"
                            }
                        ],
                        "hideHeader": true
                    }
                ]
            },
            {
                "title": "Disk $monitor_disk",
                "collapse": false,
                "repeat": "monitor_disk",
                "rows": [
                    {
                        "class": "row",
                        "gridPos": {
                            "h": 2
                        },
                        "height": "25px",
                        "panels": [
                            {
                                "class": "plain_text",
                                "spec/vizConfig/spec/options/content": "<h1 style=\"color:#5780C1; border-bottom: 3px solid #5780C1;\">Disk $monitor_disk</h1>"
                            }
                        ],
                        "hideHeader": true
                    },
                    {
                        "class": "row",
                        "panels": [
                            {
                                "span": 3,
                                "class": "wps_panel",
                                "spec/title": "Disk Writes per $by",
                                "spec/data/spec/queries": [
                                    {
                                        "class": "graph_query",
                                        "spec/query/spec/expr": "sum(rate(node_disk_writes_completed_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_disk\", job=~\"node_exporter.*\"}[4m])) by ([[by]])"
                                    },
                                    {
                                        "class": "graph_query",
                                        "spec/refId": "B",
                                        "spec/query/spec/expr": "sum(rate(node_disk_writes_completed{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_disk\", job=~\"node_exporter.*\"}[4m])) by ([[by]])"
                                    }
                                ]
                            },
                            {
                                "span": 3,
                                "class": "rps_panel",
                                "spec/title": "Disk Reads per $by",
                                "spec/data/spec/queries": [
                                    {
                                        "class": "graph_query",
                                        "spec/query/spec/expr": "sum(rate(node_disk_reads_completed_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_disk\", job=~\"node_exporter.*\"}[4m])) by ([[by]])"
                                    },
                                    {
                                        "class": "graph_query",
                                        "spec/refId": "B",
                                        "spec/query/spec/expr": "sum(rate(node_disk_reads_completed{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_disk\", job=~\"node_exporter.*\"}[4m])) by ([[by]])"
                                    }
                                ]
                            },
                            {
                                "span": 3,
                                "class": "bps_panel",
                                "spec/title": "Disk Writes Bps per $by",
                                "spec/data/spec/queries": [
                                    {
                                        "class": "graph_query",
                                        "spec/query/spec/expr": "sum(rate(node_disk_written_bytes_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_disk\", job=~\"node_exporter.*\"}[4m])) by ([[by]])"
                                    },
                                    {
                                        "class": "graph_query",
                                        "spec/refId": "B",
                                        "spec/query/spec/expr": "sum(rate(node_disk_bytes_written{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_disk\", job=~\"node_exporter.*\"}[4m])) by ([[by]])"
                                    }
                                ]
                            },
                            {
                                "span": 3,
                                "class": "bps_panel",
                                "spec/title": "Disk Read Bps per $by",
                                "spec/data/spec/queries": [
                                    {
                                        "class": "graph_query",
                                        "spec/query/spec/expr": "sum(rate(node_disk_read_bytes_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_disk\", job=~\"node_exporter.*\"}[4m])) by ([[by]])"
                                    },
                                    {
                                        "class": "graph_query",
                                        "spec/refId": "B",
                                        "spec/query/spec/expr": "sum(rate(node_disk_bytes_read{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_disk\", job=~\"node_exporter.*\"}[4m])) by ([[by]])"
                                    }
                                ]
                            },
                            {
                                "span": 3,
                                "class": "seconds_panel",
                                "spec/title": "Read AWait per instance",
                                "spec/description": "The average read time from disk",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "rate(node_disk_read_time_seconds_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_disk\", job=~\"node_exporter.*\"}[4m])/rate(node_disk_reads_completed_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_disk\", job=~\"node_exporter.*\"}[4m])",
                                "spec/data/spec/queries/0/spec/query/spec/legendFormat": "{{dc}} {{instance}}"
                            },
                            {
                                "span": 3,
                                "class": "seconds_panel",
                                "spec/title": "Write AWait per instance",
                                "spec/description": "The average write time to disk",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "rate(node_disk_write_time_seconds_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_disk\", job=~\"node_exporter.*\"}[4m])/rate(node_disk_writes_completed_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_disk\", job=~\"node_exporter.*\"}[4m])",
                                "spec/data/spec/queries/0/spec/query/spec/legendFormat": "{{dc}} {{instance}}"
                            }
                        ],
                        "hideHeader": true
                    }
                ]
            },
            {
                "title": "Network Interface $monitor_network_interface",
                "collapse": false,
                "repeat": "monitor_network_interface",
                "rows": [
                    {
                        "class": "row",
                        "gridPos": {
                            "h": 2
                        },
                        "height": "25px",
                        "panels": [
                            {
                                "class": "plain_text",
                                "spec/vizConfig/spec/options/content": "<h1 style=\"color:#5780C1; border-bottom: 3px solid #5780C1;\">Network $monitor_network_interface</h1>"
                            }
                        ],
                        "hideHeader": true
                    },
                    {
                        "class": "row",
                        "panels": [
                            {
                                "span": 6,
                                "class": "pps_panel",
                                "spec/title": "Interface Rx Packets",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(rate(node_network_receive_packets_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_network_interface\", job=~\"node_exporter.*\"}[4m])) by ([[by]])"
                            },
                            {
                                "span": 6,
                                "class": "pps_panel",
                                "spec/title": "Interface Tx Packets",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(rate(node_network_transmit_packets_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_network_interface\", job=~\"node_exporter.*\"}[4m])) by ([[by]])"
                            }
                        ],
                        "hideHeader": true
                    },
                    {
                        "class": "row",
                        "panels": [
                            {
                                "span": 6,
                                "class": "bitsps_panel",
                                "spec/title": "Interface Rx bps",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(8*rate(node_network_receive_bytes_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_network_interface\", job=~\"node_exporter.*\"}[4m])) by ([[by]])"
                            },
                            {
                                "span": 6,
                                "class": "bitsps_panel",
                                "spec/title": "Interface Tx bps",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(8*rate(node_network_transmit_bytes_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_network_interface\", job=~\"node_exporter.*\"}[4m])) by ([[by]])"
                            }
                        ],
                        "hideHeader": true
                    },
                    {
                        "class": "row",
                        "panels": [
                            {
                                "span": 6,
                                "class": "pps_panel",
                                "spec/title": "Interface Received Dropped Packets",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(rate(node_network_receive_drop_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_network_interface\", job=~\"node_exporter.*\"}[4m])) by ([[by]])"
                            },
                            {
                                "span": 6,
                                "class": "pps_panel",
                                "spec/title": "Interface Transmit Dropped Packets",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(rate(node_network_transmit_drop_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", device=\"$monitor_network_interface\", job=~\"node_exporter.*\"}[4m])) by ([[by]])"
                            }
                        ],
                        "hideHeader": true
                    }
                ]
            },
            {
                "title": "CPU and Memory",
                "collapse": false,
                "rows": [
                    {
                        "class": "row",
                        "gridPos": {
                            "h": 2
                        },
                        "height": "25px",
                        "panels": [
                            {
                                "class": "plain_text",
                                "spec/vizConfig/spec/options/content": "<h1 style=\"color:#5780C1; border-bottom: 3px solid #5780C1;\">CPU and Memory</h1>"
                            }
                        ],
                        "hideHeader": true
                    },
                    {
                        "class": "row",
                        "panels": [
                            {
                                "span": 3,
                                "class": "bytes_panel",
                                "spec/title": "Available memory",
                                "spec/description": "The available memory, note that in a production environment we expect this to be low, Scylla would use most of the available memory when possible",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(node_memory_MemAvailable_bytes{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", job=~\"node_exporter.*\"}) by ([[by]])"
                            },
                            {
                                "span": 3,
                                "class": "percentunit_panel",
                                "spec/title": "Percent of Available memory",
                                "spec/description": "Percent of available memory, note that in a production environment we expect this to be low, Scylla would use most of the available memory when possible",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(node_memory_MemAvailable_bytes{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", job=~\"node_exporter.*\"}) by ([[by]])/sum(node_memory_MemTotal_bytes{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", job=~\"node_exporter.*\"}) by ([[by]])"
                            },
                            {
                                "span": 3,
                                "class": "percentunit_panel",
                                "spec/title": "CPU used",
                                "spec/description": "Percent of CPU used, note that in production Scylla would try to use most of the CPU and this is not a problem",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "1-sum(rate(node_cpu_seconds_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", mode=\"idle\", job=~\"node_exporter.*\"}[3m])) by ([[by]])/count(node_cpu_seconds_total{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", mode=\"idle\", job=~\"node_exporter.*\"}) by ([[by]])"
                            },
                            {
                                "span": 3,
                                "class": "graph_panel",
                                "spec/title": "CPU Frequency",
                                "spec/description": "CPU frequency should be set for performance.\n\n The current frequency should match the max frequency. If that is not the case, check your host configuration.",
                                "spec/vizConfig/spec/fieldConfig": {
                                    "defaults": {
                                        "links": [],
                                        "unit": "hertz"
                                    },
                                    "overrides": []
                                },
                                "spec/data/spec/queries": [
                                    {
                                        "class": "graph_query",
                                        "spec/query/spec/expr": "max(node_cpu_scaling_frequency_max_hertz{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", job=~\"node_exporter.*\"}) or on() max(node_cpu_frequency_max_hertz{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", job=~\"node_exporter.*\"})",
                                        "spec/query/spec/legendFormat": "Max"
                                    },
                                    {
                                        "class": "graph_query",
                                        "spec/refId": "B",
                                        "spec/query/spec/expr": "min(node_cpu_scaling_frequency_hertz{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", job=~\"node_exporter.*\"}) by ([[by]]) or on() min(node_cpu_frequency_hertz{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\", job=~\"node_exporter.*\"}) by ([[by]])"
                                    }
                                ],
                                "spec/vizConfig/spec/fieldConfig/overrides": [
                                    {
                                        "matcher": {
                                            "id": "byName",
                                            "options": "Max"
                                        },
                                        "properties": [
                                            {
                                                "id": "color",
                                                "value": {
                                                    "mode": "fixed",
                                                    "fixedColor": "#F2495C"
                                                }
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "span": 3,
                                "class": "graph_panel",
                                "spec/title": "TCP Retransmit",
                                "spec/description": "reports the number of TCP segments that have been retransmitted, indicating potential network issues or packet loss.",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(rate(node_netstat_Tcp_RetransSegs{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\"}[3m])) by ([[by]])"
                            }
                        ],
                        "hideHeader": true
                    }
                ]
            },
            {
                "title": "ethtool limitations - only applicable if ethtool is enabled on nodetool_exporter",
                "collapse": true,
                "rows": [
                    {
                        "class": "row",
                        "dashversion": [
                            ">2025.4"
                        ],
                        "panels": [
                            {
                                "span": 3,
                                "class": "graph_panel",
                                "spec/title": "Bandwidth-Out allowance exceeded",
                                "spec/description": "Outbound bandwidth allowance exceed events per second — the rate at which the NIC attempts to transmit above its allowed egress bandwidth limit (often indicating throttling/shaping).",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(rate(node_ethtool_bw_out_allowance_exceeded{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\"}[3m])) by ([[by]])"
                            },
                            {
                                "span": 3,
                                "class": "graph_panel",
                                "spec/title": "Bandwidth-In allowance exceeded",
                                "spec/description": "Inbound bandwidth allowance exceed events per second — the rate at which the NIC receives above its allowed ingress bandwidth limit (often indicating ingress shaping/throttling).",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(rate(node_ethtool_bw_in_allowance_exceeded{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\"}[3m])) by ([[by]])"
                            },
                            {
                                "span": 3,
                                "class": "graph_panel",
                                "spec/title": "Conntrack allowance exceed",
                                "spec/description": "Conntrack allowance exceed events per second — the rate at which the system/NIC exceeds its allowed connection-tracking (conntrack) limit, often indicating connection pressure and potential drops or throttling.",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(rate(node_ethtool_conntrack_allowance_exceeded{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\"}[3m])) by ([[by]])"
                            },
                            {
                                "span": 3,
                                "class": "graph_panel",
                                "spec/title": "Link-local allowance exceed",
                                "spec/description": "Link-local allowance exceed events per second — the rate at which the NIC exceeds its allowed link-local traffic limit (e.g., ARP/ND or other local control traffic), often indicating local-network chatter and possible throttling",
                                "spec/data/spec/queries/0/spec/query/spec/expr": "sum(rate(node_ethtool_linklocal_allowance_exceeded{instance=~\"[[node]]\",cluster=\"$cluster\", dc=~\"$dc\"}[3m])) by ([[by]])"
                            }
                        ]
                    },
                    {
                        "class": "monitoring_version_row"
                    }
                ]
            }
        ],
        "tags": [
            "__SCYLLA_VERSION_DOT__"
        ],
        "time": {
            "from": "now-30m",
            "to": "now"
        },
